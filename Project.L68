00001B4A  5287                    1268      ADD.L   #1,         D7
00001B4C  60E2                    1269      BRA     INIT_BRIGHT_LOOP
00001B4E                          1270      
00001B4E                          1271  INIT_BRIGHT_DONE:
00001B4E  4CDF 03FF               1272      MOVEM.L (SP)+,D0-D7/A0-A1       ; Restore registers
00001B52  4E75                    1273      RTS
