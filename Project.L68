00001B58                          1281      
00001B58  41F9 000025C6           1282      LEA     STAR_X,     A0
00001B5E  43F9 00002666           1283      LEA     STAR_Y,     A1
00001B64  45F9 00002706           1284      LEA     STAR_BRIGHT,A2
00001B6A  7E00                    1285      MOVE.L  #0,         D7          ; Counter
00001B6C                          1286      
00001B6C                          1287  DRAW_STAR_LOOP:
