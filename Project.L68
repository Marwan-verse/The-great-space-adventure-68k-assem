00001D96                          1531  *-----------------------------------------------------------
00001D96                          1532  * Subroutine    : Check Next Wave
00001D96                          1533  * Description   : If all aliens dead, spawn next wave (faster)
00001D96                          1534  *-----------------------------------------------------------
00001D96                          1535  CHECK_NEXT_WAVE:
00001D96  41F9 0000242A           1536      LEA     ALIENS,     A0
00001D9C  7E11                    1537      MOVE.L  #(ALIEN_ROWS*ALIEN_COLS)-1, D7
00001D9E                          1538      
00001D9E                          1539  CHECK_WAVE_LOOP:
00001D9E  2218                    1540      MOVE.L  (A0)+,      D1
00001DA0  B2BC 00000001           1541      CMP.L   #1,         D1          ; Any alien alive?
00001DA6  6700 0048               1542      BEQ     WAVE_NOT_DONE
00001DAA  51CF FFF2               1543      DBRA    D7,         CHECK_WAVE_LOOP
00001DAE                          1544      
00001DAE                          1545      ; All aliens dead - spawn next wave!
00001DAE  6100 FE50               1546      BSR     PLAY_HIT                ; Sound for new wave
00001DB2                          1547      
00001DB2                          1548      ; Increment wave number
00001DB2  2239 000025BA           1549      MOVE.L  WAVE_NUM,   D1
00001DB8  5281                    1550      ADD.L   #1,         D1
00001DBA  23C1 000025BA           1551      MOVE.L  D1,         WAVE_NUM
00001DC0                          1552      
00001DC0                          1553      ; Increase alien speed by 3 each wave
00001DC0  2239 000025BE           1554      MOVE.L  CURRENT_ALIEN_SPD,D1
00001DC6  5681                    1555      ADD.L   #3,         D1          ; Add 3 speed per wave
00001DC8  B2BC 00000014           1556      CMP.L   #20,        D1          ; Cap at speed 20
00001DCE  6F00 0004               1557      BLE     SET_NEW_SPEED
00001DD2  7214                    1558      MOVE.L  #20,        D1
00001DD4                          1559  SET_NEW_SPEED:
00001DD4  23C1 000025BE           1560      MOVE.L  D1,         CURRENT_ALIEN_SPD
00001DDA                          1561      
00001DDA                          1562      ; Reset aliens
00001DDA  6100 F47E               1563      BSR     INIT_ALIENS
00001DDE                          1564      
00001DDE                          1565      ; Add bonus points for completing wave
00001DDE  2239 0000240E           1566      MOVE.L  PLAYER_SCORE,D1
00001DE4  0681 00000032           1567      ADD.L   #50,        D1          ; 50 bonus points per wave
00001DEA  23C1 0000240E           1568      MOVE.L  D1,         PLAYER_SCORE
00001DF0                          1569      
00001DF0                          1570  WAVE_NOT_DONE:
00001DF0  4E75                    1571      RTS
00001DF2                          1572  
