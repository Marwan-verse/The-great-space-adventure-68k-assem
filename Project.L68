00002052                          1848  * Subroutine    : Update Slow Motion
00002052                          1849  * Description   : Check if slow motion should end
00002052                          1850  *-----------------------------------------------------------
00002052                          1851  UPDATE_SLOW_MOTION:
00002052                          1852      ; Check if slow motion is active
00002052  2239 000025AA           1853      MOVE.L  SLOW_ACTIVE,D1
00002058  B2BC 00000000           1854      CMP.L   #0,         D1
0000205E  6700 0036               1855      BEQ     SLOW_UPDATE_DONE
00002062                          1856      
00002062                          1857      ; Check if duration has ended
00002062  103C 0008               1858      MOVE.B  #8,         D0          ; Get current time
00002066  4E4F                    1859      TRAP    #15
00002068  2401                    1860      MOVE.L  D1,         D2          ; Current time in D2
0000206A  2639 000025AE           1861      MOVE.L  SLOW_END_TIME,D3
00002070  B483                    1862      CMP.L   D3,         D2          ; Current time >= end time?
00002072  6D00 0022               1863      BLT     SLOW_UPDATE_DONE        ; Not yet
00002076                          1864      
00002076                          1865      ; Deactivate slow motion
00002076  23FC 00000000 000025AA  1866      MOVE.L  #0,         SLOW_ACTIVE
00002080  23FC 00000000 000025B6  1867      MOVE.L  #0,         SLOW_FRAME
0000208A                          1868      
0000208A                          1869      ; Set cooldown ready time = current time + cooldown
0000208A  0682 000007D0           1870      ADD.L   #SLOW_COOLDOWN,D2
00002090  23C2 000025B2           1871      MOVE.L  D2,         SLOW_READY_TIME
00002096                          1872      
00002096                          1873  SLOW_UPDATE_DONE:
00002096  4E75                    1874      RTS
