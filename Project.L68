00001952                          1040  *-----------------------------------------------------------
00001952                          1041  * Subroutine    : Draw Aliens
00001952                          1042  * Description   : Draw all alive aliens as cool space invaders
00001952                          1043  *-----------------------------------------------------------
00001952                          1044  DRAW_ALIENS:
00001952  41F9 0000242A           1045      LEA     ALIENS,     A0          ; Load aliens array
00001958  7E00                    1046      MOVE.L  #0,         D7          ; Counter for alien index
0000195A                          1047      
0000195A                          1048  DRAW_ALIEN_LOOP:
0000195A  BEBC 00000012           1049      CMP.L   #(ALIEN_ROWS*ALIEN_COLS), D7
00001960  6C00 014A               1050      BGE     DRAW_ALIENS_DONE
00001964                          1051      
00001964                          1052      ; Check if this alien is alive
00001964  2218                    1053      MOVE.L  (A0)+,      D1          ; Get alien status
00001966  B2BC 00000000           1054      CMP.L   #0,         D1
0000196C  6700 0138               1055      BEQ     NEXT_ALIEN              ; Dead, skip drawing
00001970                          1056      
00001970                          1057      ; Calculate alien position
00001970                          1058      ; Row = D7 / ALIEN_COLS
00001970                          1059      ; Col = D7 % ALIEN_COLS
00001970  2607                    1060      MOVE.L  D7,         D3
00001972  86FC 0009               1061      DIVU    #ALIEN_COLS,D3          ; D3.W = row, high word = col
00001976  3803                    1062      MOVE.W  D3,         D4          ; D4 = row
00001978  4843                    1063      SWAP    D3
0000197A  3A03                    1064      MOVE.W  D3,         D5          ; D5 = col
0000197C                          1065      
0000197C                          1066      ; Calculate X position: ALIENS_X + col * ALIEN_GAP
0000197C  4281                    1067      CLR.L   D1
0000197E  3205                    1068      MOVE.W  D5,         D1
00001980  C2FC 0028               1069      MULU    #ALIEN_GAP, D1
00001984  D2B9 0000241E           1070      ADD.L   ALIENS_X,   D1          ; Alien X
0000198A                          1071      
0000198A                          1072      ; Calculate Y position: ALIENS_Y + row * (ALIEN_H + 10)
0000198A  4282                    1073      CLR.L   D2
0000198C  3404                    1074      MOVE.W  D4,         D2
0000198E  C4FC 0014               1075      MULU    #(ALIEN_H+10),D2
00001992  D4B9 00002422           1076      ADD.L   ALIENS_Y,   D2          ; Alien Y
00001998                          1077      
00001998                          1078      ; Save base X,Y in A1,A2 for drawing parts
00001998  2641                    1079      MOVE.L  D1,         A3          ; Save base X
0000199A  2842                    1080      MOVE.L  D2,         A4          ; Save base Y
0000199C                          1081      
