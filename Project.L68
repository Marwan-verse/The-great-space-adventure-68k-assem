00001B72  6C00 004E               1289      BGE     DRAW_STARS_DONE
00001B76                          1290      
00001B76                          1291      ; Get brightness level for color
00001B76  2C1A                    1292      MOVE.L  (A2)+,      D6
00001B78                          1293      
00001B78                          1294      ; Set star color based on brightness
00001B78  BCBC 00000000           1295      CMP.L   #0,         D6
00001B7E  6700 0016               1296      BEQ     .DIM_STAR
00001B82  BCBC 00000001           1297      CMP.L   #1,         D6
00001B88  6700 0016               1298      BEQ     .MED_STAR
00001B8C                          1299      
00001B8C                          1300      ; Bright star - white
