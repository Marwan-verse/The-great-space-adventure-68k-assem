00001AAE                          1206  *-----------------------------------------------------------
00001AAE                          1207  * Subroutine    : Initialize Stars
00001AAE                          1208  * Description   : Set up random star positions
00001AAE                          1209  *-----------------------------------------------------------
00001AAE                          1210  INIT_STARS:
00001AAE  48E7 FFC0               1211      MOVEM.L D0-D7/A0-A1,-(SP)       ; Save registers
00001AB2  41F9 000025C6           1212      LEA     STAR_X,     A0
00001AB8  43F9 00002666           1213      LEA     STAR_Y,     A1
00001ABE                          1214      
00001ABE                          1215      ; Generate pseudo-random star positions using fixed seed pattern
00001ABE  7E00                    1216      MOVE.L  #0,         D7          ; Counter
00001AC0  7825                    1217      MOVE.L  #37,        D4          ; Seed X
00001AC2  7A5B                    1218      MOVE.L  #91,        D5          ; Seed Y
00001AC4                          1219      
00001AC4                          1220  INIT_STAR_LOOP:
00001AC4  BEBC 00000028           1221      CMP.L   #NUM_STARS, D7
00001ACA  6C00 005A               1222      BGE     INIT_STARS_DONE
00001ACE                          1223      
00001ACE                          1224      ; Calculate X position (pseudo-random)
00001ACE  2004                    1225      MOVE.L  D4,         D0
00001AD0  C0FC 007F               1226      MULU    #127,       D0
00001AD4  0680 00000011           1227      ADD.L   #17,        D0
00001ADA  80FC 0244               1228      DIVU    #SCR_WIDTH, D0          ; Remainder in upper word
00001ADE  4840                    1229      SWAP    D0
00001AE0  C0BC 0000FFFF           1230      AND.L   #$FFFF,     D0
00001AE6  20C0                    1231      MOVE.L  D0,         (A0)+       ; Store X
00001AE8  2800                    1232      MOVE.L  D0,         D4          ; Update seed
00001AEA  0684 00000049           1233      ADD.L   #73,        D4
00001AF0                          1234      
00001AF0                          1235      ; Calculate Y position (pseudo-random)
00001AF0  2005                    1236      MOVE.L  D5,         D0
00001AF2  C0FC 0061               1237      MULU    #97,        D0
00001AF6  0680 00000035           1238      ADD.L   #53,        D0
00001AFC  223C 00000334           1239      MOVE.L  #SCR_HEIGHT,D1
00001B02  0481 00000064           1240      SUB.L   #100,       D1          ; Keep stars above HUD area
00001B08  80C1                    1241      DIVU    D1,         D0          ; Remainder in upper word
00001B0A  4840                    1242      SWAP    D0
00001B0C  C0BC 0000FFFF           1243      AND.L   #$FFFF,     D0
00001B12  0680 0000003C           1244      ADD.L   #60,        D0          ; Below top HUD
00001B18  22C0                    1245      MOVE.L  D0,         (A1)+       ; Store Y
00001B1A  2A00                    1246      MOVE.L  D0,         D5          ; Update seed
00001B1C  0685 00000029           1247      ADD.L   #41,        D5
00001B22                          1248      
00001B22  5287                    1249      ADD.L   #1,         D7
00001B24  609E                    1250      BRA     INIT_STAR_LOOP
00001B26                          1251      
00001B26                          1252  INIT_STARS_DONE:
00001B26                          1253      ; Set star brightness
00001B26  41F9 00002706           1254      LEA     STAR_BRIGHT,A0
00001B2C  7E00                    1255      MOVE.L  #0,         D7
00001B2E  7800                    1256      MOVE.L  #0,         D4          ; Brightness cycle
00001B30                          1257      
00001B30                          1258  INIT_BRIGHT_LOOP:
00001B30  BEBC 00000028           1259      CMP.L   #NUM_STARS, D7
00001B36  6C00 0016               1260      BGE     INIT_BRIGHT_DONE
00001B3A                          1261      
00001B3A  20C4                    1262      MOVE.L  D4,         (A0)+
00001B3C  5284                    1263      ADD.L   #1,         D4
00001B3E  B8BC 00000003           1264      CMP.L   #3,         D4
00001B44  6D00 0004               1265      BLT     .SKIP_RESET
00001B48  7800                    1266      MOVE.L  #0,         D4
