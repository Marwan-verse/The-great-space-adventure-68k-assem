00001C8E                          1420  *-----------------------------------------------------------
00001C8E                          1421  * Subroutine    : Check Bullet Collisions
00001C8E                          1422  * Description   : Check if bullet hits any alien
00001C8E                          1423  *-----------------------------------------------------------
00001C8E                          1424  CHECK_BULLET_COLLISIONS:
00001C8E                          1425      ; Check if bullet is active
00001C8E  2239 0000241A           1426      MOVE.L  BULLET_ACT, D1
00001C94  B2BC 00000000           1427      CMP.L   #0,         D1
00001C9A  6700 00CE               1428      BEQ     BULLET_COLL_DONE        ; Not active, skip
00001C9E                          1429      
00001C9E                          1430      ; Get bullet position
00001C9E  2239 00002412           1431      MOVE.L  BULLET_X,   D1          ; Bullet X
00001CA4  2439 00002416           1432      MOVE.L  BULLET_Y,   D2          ; Bullet Y
00001CAA                          1433      
00001CAA  41F9 0000242A           1434      LEA     ALIENS,     A0          ; Load aliens array
00001CB0  7E00                    1435      MOVE.L  #0,         D7          ; Counter
00001CB2                          1436      
00001CB2                          1437  CHECK_ALIEN_COLL_LOOP:
00001CB2  BEBC 00000012           1438      CMP.L   #(ALIEN_ROWS*ALIEN_COLS), D7
00001CB8  6C00 00B0               1439      BGE     BULLET_COLL_DONE
00001CBC                          1440      
00001CBC                          1441      ; Check if alien is alive
00001CBC  2248                    1442      MOVE.L  A0,         A1          ; Save A0
00001CBE  2C07                    1443      MOVE.L  D7,         D6
00001CC0  CCFC 0004               1444      MULU    #4,         D6
00001CC4  D3C6                    1445      ADDA.L  D6,         A1
00001CC6  2611                    1446      MOVE.L  (A1),       D3
00001CC8  B6BC 00000000           1447      CMP.L   #0,         D3
00001CCE  6700 0094               1448      BEQ     NEXT_ALIEN_COLL         ; Dead, skip
00001CD2                          1449      
00001CD2                          1450      ; Calculate alien position
00001CD2  2607                    1451      MOVE.L  D7,         D3
00001CD4  86FC 0009               1452      DIVU    #ALIEN_COLS,D3          ; D3.W = row
00001CD8  3803                    1453      MOVE.W  D3,         D4          ; D4 = row
00001CDA  4843                    1454      SWAP    D3
00001CDC  3A03                    1455      MOVE.W  D3,         D5          ; D5 = col
00001CDE                          1456      
00001CDE                          1457      ; Calculate alien X: ALIENS_X + col * ALIEN_GAP
00001CDE  4283                    1458      CLR.L   D3
00001CE0  3605                    1459      MOVE.W  D5,         D3
00001CE2  C6FC 0028               1460      MULU    #ALIEN_GAP, D3
00001CE6  D6B9 0000241E           1461      ADD.L   ALIENS_X,   D3          ; Alien X in D3
00001CEC                          1462      
00001CEC                          1463      ; Calculate alien Y: ALIENS_Y + row * (ALIEN_H + 10)
00001CEC  4286                    1464      CLR.L   D6
00001CEE  3C04                    1465      MOVE.W  D4,         D6
00001CF0  CCFC 0014               1466      MULU    #(ALIEN_H+10),D6
00001CF4  DCB9 00002422           1467      ADD.L   ALIENS_Y,   D6          ; Alien Y in D6
00001CFA                          1468      
00001CFA                          1469      ; Simple AABB collision check
00001CFA                          1470      ; Bullet center vs alien bounds
00001CFA  2239 00002412           1471      MOVE.L  BULLET_X,   D1
00001D00  5281                    1472      ADD.L   #BULLET_W/2,D1          ; Bullet center X
00001D02                          1473      
00001D02                          1474      ; Check X bounds
00001D02  B283                    1475      CMP.L   D3,         D1          ; Bullet X < Alien X?
00001D04  6D00 005E               1476      BLT     NEXT_ALIEN_COLL
00001D08  2803                    1477      MOVE.L  D3,         D4
00001D0A  0684 00000028           1478      ADD.L   #ALIEN_W,   D4
00001D10  B284                    1479      CMP.L   D4,         D1          ; Bullet X > Alien X + W?
00001D12  6E00 0050               1480      BGT     NEXT_ALIEN_COLL
00001D16                          1481      
00001D16                          1482      ; Check Y bounds
00001D16  2439 00002416           1483      MOVE.L  BULLET_Y,   D2
00001D1C  B486                    1484      CMP.L   D6,         D2          ; Bullet Y < Alien Y?
00001D1E  6D00 0044               1485      BLT     NEXT_ALIEN_COLL
00001D22  2806                    1486      MOVE.L  D6,         D4
00001D24  0684 0000000A           1487      ADD.L   #ALIEN_H,   D4
00001D2A  B484                    1488      CMP.L   D4,         D2          ; Bullet Y > Alien Y + H?
00001D2C  6E00 0036               1489      BGT     NEXT_ALIEN_COLL
00001D30                          1490      
00001D30                          1491      ; HIT! Kill alien and deactivate bullet
00001D30  6100 FECE               1492      BSR     PLAY_HIT
00001D34  22BC 00000000           1493      MOVE.L  #0,         (A1)        ; Kill alien
00001D3A  23FC 00000000 0000241A  1494      MOVE.L  #0,         BULLET_ACT  ; Deactivate bullet
00001D44  23FC 00000082 00002416  1495      MOVE.L  #BULLET_OFF,BULLET_Y
00001D4E                          1496      
00001D4E                          1497      ; Add points
00001D4E  2239 0000240E           1498      MOVE.L  PLAYER_SCORE,D1
00001D54  0681 0000000A           1499      ADD.L   #POINTS,    D1
00001D5A  23C1 0000240E           1500      MOVE.L  D1,         PLAYER_SCORE
00001D60                          1501      
00001D60  6000 0008               1502      BRA     BULLET_COLL_DONE
00001D64                          1503      
00001D64                          1504  NEXT_ALIEN_COLL:
00001D64  5287                    1505      ADD.L   #1,         D7
00001D66  6000 FF4A               1506      BRA     CHECK_ALIEN_COLL_LOOP
00001D6A                          1507      
00001D6A                          1508  BULLET_COLL_DONE:
00001D6A  4E75                    1509      RTS
00001D6C                          1510  
00001D6C                          1511  *-----------------------------------------------------------
00001D6C                          1512  * Subroutine    : Check if aliens reached bottom
00001D6C                          1513  * Description   : Game over if aliens reach ship
00001D6C                          1514  *-----------------------------------------------------------
00001D6C                          1515  CHECK_ALIEN_REACHED:
00001D6C                          1516      ; Calculate lowest alien Y position
00001D6C  2239 00002422           1517      MOVE.L  ALIENS_Y,   D1
00001D72  0681 00000028           1518      ADD.L   #(ALIEN_ROWS*(ALIEN_H+10)), D1
00001D78                          1519      
00001D78                          1520      ; Compare with ship Y
00001D78  2439 0000240A           1521      MOVE.L  SHIP_Y,     D2
00001D7E  B282                    1522      CMP.L   D2,         D1
00001D80  6C00 0004               1523      BGE     SET_GAME_OVER
00001D84  4E75                    1524      RTS
00001D86                          1525  
00001D86                          1526  SET_GAME_OVER:
00001D86  6100 FE9E               1527      BSR     PLAY_OPPS
00001D8A  23FC 00000001 00002472  1528      MOVE.L  #1,         GAME_OVER
00001D94  4E75                    1529      RTS
