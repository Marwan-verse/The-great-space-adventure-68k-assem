00001DF2                          1574  * Subroutine    : Init Alien Bullets
00001DF2                          1575  * Description   : Initialize alien bullet array
00001DF2                          1576  *-----------------------------------------------------------
00001DF2                          1577  INIT_ALIEN_BULLETS:
00001DF2  41F9 0000253E           1578      LEA     ALN_BLT_ACT,A0
00001DF8  7E18                    1579      MOVE.L  #MAX_ALN_BLT-1,D7
00001DFA                          1580  INIT_ABL_LOOP:
00001DFA  20FC 00000000           1581      MOVE.L  #0,         (A0)+       ; Set inactive
00001E00  51CF FFF8               1582      DBRA    D7,         INIT_ABL_LOOP
00001E04  4E75                    1583      RTS
00001E06                          1584  
00001E06                          1585  *-----------------------------------------------------------
00001E06                          1586  * Subroutine    : Alien Shoot Random
00001E06                          1587  * Description   : Randomly fire bullets from alive aliens
00001E06                          1588  *-----------------------------------------------------------
00001E06                          1589  ALIEN_SHOOT_RANDOM:
00001E06                          1590      ; Generate random number to decide if we shoot
00001E06  6100 022A               1591      BSR     GET_RANDOM
00001E0A  C2BC 000000FF           1592      AND.L   #$FF,       D1          ; Limit to 0-255
00001E10  B2BC 00000004           1593      CMP.L   #4,         D1          ; ~1.5% chance each frame
00001E16  6E00 00A0               1594      BGT     NO_ALIEN_SHOT
00001E1A                          1595      
00001E1A                          1596      ; Count alive aliens first
00001E1A  41F9 0000242A           1597      LEA     ALIENS,     A0
00001E20  7A00                    1598      MOVE.L  #0,         D5          ; Alive count
00001E22  7E11                    1599      MOVE.L  #(ALIEN_ROWS*ALIEN_COLS)-1, D7
00001E24                          1600  COUNT_ALIVE_LOOP:
00001E24  2218                    1601      MOVE.L  (A0)+,      D1
00001E26  B2BC 00000001           1602      CMP.L   #1,         D1
00001E2C  6600 0004               1603      BNE     .NOT_ALIVE
00001E30  5285                    1604      ADD.L   #1,         D5
00001E32                          1605  .NOT_ALIVE:
00001E32  51CF FFF0               1606      DBRA    D7,         COUNT_ALIVE_LOOP
00001E36                          1607      
00001E36                          1608      ; If no aliens alive, skip
00001E36  BABC 00000000           1609      CMP.L   #0,         D5
00001E3C  6700 007A               1610      BEQ     NO_ALIEN_SHOT
00001E40                          1611      
00001E40                          1612      ; Pick random index from 0 to (alive_count-1)
00001E40  6100 01F0               1613      BSR     GET_RANDOM
00001E44  C2BC 0000FFFF           1614      AND.L   #$FFFF,     D1
00001E4A  82C5                    1615      DIVU    D5,         D1          ; D1.W = quotient, high word = remainder
00001E4C  4841                    1616      SWAP    D1
00001E4E  C2BC 0000FFFF           1617      AND.L   #$FFFF,     D1          ; D1 = random index (0 to alive_count-1)
00001E54                          1618      
00001E54                          1619      ; Find the Nth alive alien
00001E54  41F9 0000242A           1620      LEA     ALIENS,     A0
00001E5A  7E00                    1621      MOVE.L  #0,         D7          ; Alien array index
00001E5C  7CFF                    1622      MOVE.L  #-1,        D6          ; Alive counter (will increment to 0 on first find)
00001E5E                          1623      
00001E5E                          1624  FIND_NTH_ALIEN:
00001E5E  BEBC 00000012           1625      CMP.L   #(ALIEN_ROWS*ALIEN_COLS), D7
00001E64  6C00 0052               1626      BGE     NO_ALIEN_SHOT           ; Safety check
00001E68                          1627      
00001E68  2418                    1628      MOVE.L  (A0)+,      D2
00001E6A  B4BC 00000001           1629      CMP.L   #1,         D2
00001E70  6600 000A               1630      BNE     .SKIP_DEAD
00001E74                          1631      
00001E74                          1632      ; Found alive alien, increment counter
00001E74  5286                    1633      ADD.L   #1,         D6
00001E76  BC81                    1634      CMP.L   D1,         D6          ; Is this the one we want?
00001E78  6700 0006               1635      BEQ     ALIEN_SELECTED
00001E7C                          1636      
00001E7C                          1637  .SKIP_DEAD:
00001E7C  5287                    1638      ADD.L   #1,         D7
00001E7E  60DE                    1639      BRA     FIND_NTH_ALIEN
00001E80                          1640      
00001E80                          1641  ALIEN_SELECTED:
00001E80                          1642      ; D7 now has the alien index
00001E80                          1643      ; Calculate alien position for bullet spawn
00001E80  2607                    1644      MOVE.L  D7,         D3
00001E82  86FC 0009               1645      DIVU    #ALIEN_COLS,D3
00001E86  3803                    1646      MOVE.W  D3,         D4          ; Row
00001E88  4843                    1647      SWAP    D3
00001E8A  3A03                    1648      MOVE.W  D3,         D5          ; Col
00001E8C                          1649      
00001E8C                          1650      ; Alien X position
00001E8C  4281                    1651      CLR.L   D1
00001E8E  3205                    1652      MOVE.W  D5,         D1
00001E90  C2FC 0028               1653      MULU    #ALIEN_GAP, D1
00001E94  D2B9 0000241E           1654      ADD.L   ALIENS_X,   D1
00001E9A  0681 00000014           1655      ADD.L   #ALIEN_W/2, D1          ; Center of alien
00001EA0                          1656      
00001EA0                          1657      ; Alien Y position
00001EA0  4282                    1658      CLR.L   D2
00001EA2  3404                    1659      MOVE.W  D4,         D2
00001EA4  C4FC 0014               1660      MULU    #(ALIEN_H+10),D2
00001EA8  D4B9 00002422           1661      ADD.L   ALIENS_Y,   D2
00001EAE  0682 0000000A           1662      ADD.L   #ALIEN_H,   D2          ; Bottom of alien
00001EB4                          1663      
00001EB4                          1664      ; Find inactive bullet slot
00001EB4  6100 0004               1665      BSR     FIRE_ALIEN_BULLET
00001EB8                          1666      
00001EB8                          1667  NO_ALIEN_SHOT:
00001EB8  4E75                    1668      RTS
00001EBA                          1669  
00001EBA                          1670  *-----------------------------------------------------------
00001EBA                          1671  * Subroutine    : Fire Alien Bullet
00001EBA                          1672  * Description   : Spawn alien bullet at D1,D2 position
00001EBA                          1673  *-----------------------------------------------------------
00001EBA                          1674  FIRE_ALIEN_BULLET:
00001EBA  41F9 0000253E           1675      LEA     ALN_BLT_ACT,A0
00001EC0  43F9 00002476           1676      LEA     ALN_BLT_X,  A1
00001EC6  45F9 000024DA           1677      LEA     ALN_BLT_Y,  A2
00001ECC  7E18                    1678      MOVE.L  #MAX_ALN_BLT-1,D7
00001ECE                          1679  FIND_SLOT:
00001ECE  2618                    1680      MOVE.L  (A0)+,      D3
00001ED0  B6BC 00000000           1681      CMP.L   #0,         D3
00001ED6  6700 000C               1682      BEQ     FOUND_SLOT
00001EDA  5889                    1683      ADDA.L  #4,         A1
00001EDC  588A                    1684      ADDA.L  #4,         A2
00001EDE  51CF FFEE               1685      DBRA    D7,         FIND_SLOT
00001EE2  4E75                    1686      RTS                             ; No slots available
00001EE4                          1687      
00001EE4                          1688  FOUND_SLOT:
00001EE4  217C 00000001 FFFC      1689      MOVE.L  #1,         -4(A0)      ; Set active
00001EEC  2281                    1690      MOVE.L  D1,         (A1)        ; Set X
00001EEE  2482                    1691      MOVE.L  D2,         (A2)        ; Set Y
00001EF0  4E75                    1692      RTS
00001EF2                          1693  
00001EF2                          1694  *-----------------------------------------------------------
00001EF2                          1695  * Subroutine    : Update Alien Bullets
00001EF2                          1696  * Description   : Move alien bullets downward
00001EF2                          1697  *-----------------------------------------------------------
00001EF2                          1698  UPDATE_ALIEN_BULLETS:
00001EF2                          1699      ; Check if slow motion is active for bullet speed
00001EF2  2C39 000025AA           1700      MOVE.L  SLOW_ACTIVE,D6
00001EF8  BCBC 00000001           1701      CMP.L   #1,         D6
00001EFE  6600 0028               1702      BNE     UPDATE_ABL_NORMAL
00001F02                          1703      
00001F02                          1704      ; Slow motion active - only move every 4th frame
00001F02  2C39 000025A2           1705      MOVE.L  ABL_SLOW_CNT,D6
00001F08  5286                    1706      ADD.L   #1,         D6
00001F0A  BCBC 00000004           1707      CMP.L   #4,         D6          ; Move every 4th frame
00001F10  6D00 000E               1708      BLT     SKIP_ABL_UPDATE
00001F14  4286                    1709      CLR.L   D6
00001F16  23C6 000025A2           1710      MOVE.L  D6,         ABL_SLOW_CNT
00001F1C  6000 0014               1711      BRA     DO_ABL_UPDATE
00001F20                          1712      
00001F20                          1713  SKIP_ABL_UPDATE:
00001F20  23C6 000025A2           1714      MOVE.L  D6,         ABL_SLOW_CNT
00001F26  4E75                    1715      RTS
00001F28                          1716      
00001F28                          1717  UPDATE_ABL_NORMAL:
00001F28  23FC 00000000 000025A2  1718      MOVE.L  #0,         ABL_SLOW_CNT ; Reset counter when not in slow-mo
00001F32                          1719      
00001F32                          1720  DO_ABL_UPDATE:
00001F32  41F9 0000253E           1721      LEA     ALN_BLT_ACT,A0
00001F38  43F9 000024DA           1722      LEA     ALN_BLT_Y,  A1
00001F3E  7E18                    1723      MOVE.L  #MAX_ALN_BLT-1,D7
00001F40                          1724  UPD_ABL_LOOP:
00001F40  2210                    1725      MOVE.L  (A0),       D1
00001F42  B2BC 00000000           1726      CMP.L   #0,         D1
00001F48  6700 0020               1727      BEQ     NEXT_ABL
00001F4C                          1728      
00001F4C                          1729      ; Move bullet down
00001F4C  2211                    1730      MOVE.L  (A1),       D1
00001F4E  5281                    1731      ADD.L   #ALN_BLT_SPD,D1
00001F50  2281                    1732      MOVE.L  D1,         (A1)
00001F52                          1733      
00001F52                          1734      ; Check if off screen
00001F52  4282                    1735      CLR.L   D2
00001F54  3439 00002404           1736      MOVE.W  SCREEN_H,   D2
00001F5A  B282                    1737      CMP.L   D2,         D1
00001F5C  6C00 0006               1738      BGE     DEACT_ABL
00001F60  6000 0008               1739      BRA     NEXT_ABL
00001F64                          1740      
00001F64                          1741  DEACT_ABL:
00001F64  20BC 00000000           1742      MOVE.L  #0,         (A0)        ; Deactivate
00001F6A                          1743      
00001F6A                          1744  NEXT_ABL:
00001F6A  5888                    1745      ADDA.L  #4,         A0
00001F6C  5889                    1746      ADDA.L  #4,         A1
00001F6E  51CF FFD0               1747      DBRA    D7,         UPD_ABL_LOOP
00001F72  4E75                    1748      RTS
