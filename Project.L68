0000190E                          1011  * Subroutine    : Draw Bullet
0000190E                          1012  * Description   : Draw bullet (yellow rectangle)
0000190E                          1013  *-----------------------------------------------------------
0000190E                          1014  DRAW_BULLET:
0000190E                          1015      ; Check if bullet is active
0000190E  2239 0000241A           1016      MOVE.L  BULLET_ACT, D1
00001914  B2BC 00000000           1017      CMP.L   #0,         D1
0000191A  6700 0034               1018      BEQ     BULLET_DRAW_DONE        ; Not active, skip
0000191E                          1019      
0000191E                          1020      ; Set Pixel Colors (Yellow for bullet)
0000191E  223C 0000FFFF           1021      MOVE.L  #YELLOW,    D1          ; Set Background color
00001924  103C 0050               1022      MOVE.B  #80,        D0          ; Task for Background Color
00001928  4E4F                    1023      TRAP    #15                     ; Trap (Perform action)
0000192A                          1024  
0000192A                          1025      ; Set X, Y, Width and Height
0000192A  2239 00002412           1026      MOVE.L  BULLET_X,   D1          ; X
00001930  2439 00002416           1027      MOVE.L  BULLET_Y,   D2          ; Y
00001936  2639 00002412           1028      MOVE.L  BULLET_X,   D3
0000193C  5683                    1029      ADD.L   #BULLET_W,  D3          ; Width
0000193E  2839 00002416           1030      MOVE.L  BULLET_Y,   D4 
00001944  0684 0000000A           1031      ADD.L   #BULLET_H,  D4          ; Height
0000194A                          1032      
0000194A                          1033      ; Draw Bullet
0000194A  103C 0057               1034      MOVE.B  #87,        D0          ; Draw filled rectangle
0000194E  4E4F                    1035      TRAP    #15                     ; Trap (Perform action)
00001950                          1036      
00001950                          1037  BULLET_DRAW_DONE:
00001950  4E75                    1038      RTS                             ; Return to subroutine
