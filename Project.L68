000012F0  7226                     400      MOVE.L  #KEY_UP,    D1
000012F2  4E4F                     401      TRAP    #15
000012F4  0801 0000                402      BTST    #0,         D1
000012F8  6600 0034                403      BNE     ACTIVATE_SLOW
000012FC                           404      
000012FC                           405      ; Check for left arrow (held)
000012FC  103C 0013                406      MOVE.B  #TC_KEYCODE,D0
00001300  7225                     407      MOVE.L  #KEY_LEFT,  D1
00001302  4E4F                     408      TRAP    #15
00001304  0801 0000                409      BTST    #0,         D1
00001308  6600 007E                410      BNE     MOVE_LEFT
0000130C                           411      
0000130C                           412      ; Check for right arrow (held)
0000130C  103C 0013                413      MOVE.B  #TC_KEYCODE,D0
00001310  7227                     414      MOVE.L  #KEY_RIGHT, D1
00001312  4E4F                     415      TRAP    #15
00001314  0801 0000                416      BTST    #0,         D1
00001318  6600 0088                417      BNE     MOVE_RIGHT
0000131C                           418      
0000131C                           419      ; Check for spacebar (shoot)
0000131C  103C 0013                420      MOVE.B  #TC_KEYCODE,D0
00001320  7220                     421      MOVE.L  #SPACEBAR,  D1
00001322  4E4F                     422      TRAP    #15
00001324  0801 0000                423      BTST    #0,         D1
00001328  6600 009A                424      BNE     SHOOT
0000132C                           425      
0000132C  4E75                     426      RTS                             ; Return to subroutine
0000132E                           427  
0000132E                           428  *-----------------------------------------------------------
0000132E                           429  * Subroutine    : Activate Slow Motion
0000132E                           430  * Description   : Activate slow motion if cooldown is ready
0000132E                           431  *-----------------------------------------------------------
0000132E                           432  ACTIVATE_SLOW:
0000132E                           433      ; Check if already active
0000132E  2239 000025AA            434      MOVE.L  SLOW_ACTIVE,D1
00001334  B2BC 00000001            435      CMP.L   #1,         D1
0000133A  6700 004A                436      BEQ     ACTIVATE_SLOW_DONE      ; Already active
0000133E                           437      
0000133E                           438      ; Check if cooldown has passed
0000133E  103C 0008                439      MOVE.B  #8,         D0          ; Get current time
00001342  4E4F                     440      TRAP    #15
00001344  2401                     441      MOVE.L  D1,         D2          ; Current time in D2
00001346  2639 000025B2            442      MOVE.L  SLOW_READY_TIME,D3
0000134C  B483                     443      CMP.L   D3,         D2          ; Current time >= ready time?
0000134E  6D00 0036                444      BLT     ACTIVATE_SLOW_DONE      ; Not ready yet
00001352                           445      
00001352                           446      ; Activate slow motion!
00001352  23FC 00000001 000025AA   447      MOVE.L  #1,         SLOW_ACTIVE
0000135C                           448      
0000135C                           449      ; Play time freeze sound
0000135C  6100 091C                450      BSR     PLAY_TIMEFREEZE
00001360                           451      
00001360                           452      ; Set message display timer (show for 2 seconds = 200 hundredths)
00001360  103C 0008                453      MOVE.B  #8,         D0
00001364  4E4F                     454      TRAP    #15
00001366  0681 000000C8            455      ADD.L   #200,       D1
0000136C  23C1 000027DA            456      MOVE.L  D1,         TIMESTOP_MSG_TIME
00001372                           457      
00001372                           458      ; Set end time = current time + duration
00001372  103C 0008                459      MOVE.B  #8,         D0
00001376  4E4F                     460      TRAP    #15
00001378  2401                     461      MOVE.L  D1,         D2          ; Current time in D2
0000137A  0681 000001F4            462      ADD.L   #SLOW_DURATION,D1
00001380  23C1 000025AE            463      MOVE.L  D1,         SLOW_END_TIME
00001386                           464      
00001386                           465  ACTIVATE_SLOW_DONE:
00001386  4E75                     466      RTS
00001388                           467  
00001388                           468  *-----------------------------------------------------------
00001388                           469  * Subroutine    : Move Left
00001388                           470  * Description   : Move ship left
00001388                           471  *-----------------------------------------------------------
00001388                           472  MOVE_LEFT:
00001388  2239 00002406            473      MOVE.L  SHIP_X,     D1
0000138E  5381                     474      SUB.L   #SHIP_SPEED,D1
00001390  B2BC 00000000            475      CMP.L   #0,         D1          ; Don't go past left edge
00001396  6F00 0008                476      BLE     MOVE_LEFT_DONE
0000139A  23C1 00002406            477      MOVE.L  D1,         SHIP_X
000013A0                           478  MOVE_LEFT_DONE:
000013A0  4E75                     479      RTS
000013A2                           480  
000013A2                           481  *-----------------------------------------------------------
000013A2                           482  * Subroutine    : Move Right  
000013A2                           483  * Description   : Move ship right
000013A2                           484  *-----------------------------------------------------------
000013A2                           485  MOVE_RIGHT:
000013A2  2239 00002406            486      MOVE.L  SHIP_X,     D1
000013A8  5281                     487      ADD.L   #SHIP_SPEED,D1
000013AA  243C 00000244            488      MOVE.L  #SCR_WIDTH, D2
000013B0  0482 00000014            489      SUB.L   #SHIP_W,    D2          ; Right edge (screen width - ship width)
000013B6  B282                     490      CMP.L   D2,         D1
000013B8  6C00 0008                491      BGE     MOVE_RIGHT_DONE
000013BC  23C1 00002406            492      MOVE.L  D1,         SHIP_X
000013C2                           493  MOVE_RIGHT_DONE:
000013C2  4E75                     494      RTS
000013C4                           495  
000013C4                           496  *-----------------------------------------------------------
000013C4                           497  * Subroutine    : Shoot
000013C4                           498  * Description   : Fire bullet from ship
000013C4                           499  *-----------------------------------------------------------
000013C4                           500  SHOOT:
000013C4                           501      ; Only shoot if bullet not active
000013C4  2239 0000241A            502      MOVE.L  BULLET_ACT, D1
000013CA  B2BC 00000001            503      CMP.L   #1,         D1
000013D0  6700 0036                504      BEQ     SHOOT_DONE              ; Already active, skip
000013D4                           505      
000013D4                           506      ; Fire new bullet
000013D4  6100 0804                507      BSR     PLAY_SHOOT              ; Play shoot sound
000013D8  23FC 00000001 0000241A   508      MOVE.L  #1,         BULLET_ACT  ; Set bullet active
000013E2                           509      
000013E2                           510      ; Position bullet at center of ship
000013E2  2239 00002406            511      MOVE.L  SHIP_X,     D1
000013E8  0681 0000000A            512      ADD.L   #SHIP_W/2,  D1
000013EE  5381                     513      SUB.L   #BULLET_W/2,D1
000013F0  23C1 00002412            514      MOVE.L  D1,         BULLET_X
000013F6                           515      
000013F6  2239 0000240A            516      MOVE.L  SHIP_Y,     D1
000013FC  0481 0000000A            517      SUB.L   #BULLET_H,  D1
00001402  23C1 00002416            518      MOVE.L  D1,         BULLET_Y
00001408                           519      
00001408                           520  SHOOT_DONE:
00001408  4E75                     521      RTS
0000140A                           522  
0000140A                           523  *-----------------------------------------------------------
0000140A                           524  * Subroutine    : Update Bullet
0000140A                           525  * Description   : Move bullet upward
0000140A                           526  *-----------------------------------------------------------
0000140A                           527  UPDATE_BULLET:
0000140A                           528      ; Check if bullet is active
0000140A  2239 0000241A            529      MOVE.L  BULLET_ACT, D1
00001410  B2BC 00000000            530      CMP.L   #0,         D1
00001416  6700 0032                531      BEQ     BULLET_UPDATE_DONE      ; Not active, skip
0000141A                           532      
0000141A                           533      ; Move bullet up
0000141A  2239 00002416            534      MOVE.L  BULLET_Y,   D1
00001420  5F81                     535      SUB.L   #BULLET_SPD,D1
00001422  23C1 00002416            536      MOVE.L  D1,         BULLET_Y
00001428                           537      
00001428                           538      ; Check if bullet went off screen
00001428  B2BC 00000000            539      CMP.L   #0,         D1
0000142E  6F00 0006                540      BLE     DEACTIVATE_BULLET
00001432  6000 0016                541      BRA     BULLET_UPDATE_DONE
00001436                           542  
00001436                           543  DEACTIVATE_BULLET:
00001436  23FC 00000000 0000241A   544      MOVE.L  #0,         BULLET_ACT
00001440  23FC 00000082 00002416   545      MOVE.L  #BULLET_OFF,BULLET_Y
0000144A                           546      
0000144A                           547  BULLET_UPDATE_DONE:
0000144A  4E75                     548      RTS
0000144C                           549  
0000144C                           550  *-----------------------------------------------------------
0000144C                           551  * Subroutine    : Update Aliens
0000144C                           552  * Description   : Move aliens side to side and down
0000144C                           553  *-----------------------------------------------------------
0000144C                           554  UPDATE_ALIENS:
0000144C                           555      ; Check if slow motion is active
0000144C  2039 000025AA            556      MOVE.L  SLOW_ACTIVE,D0
00001452  B0BC 00000001            557      CMP.L   #1,         D0
00001458  6700 0044                558      BEQ     SLOW_ALIEN_MOVE
0000145C                           559      
0000145C                           560      ; Normal speed - add frame delay for slower movement
0000145C  2039 000025C2            561      MOVE.L  ALIEN_MOVE_CNT,D0
00001462  5280                     562      ADD.L   #1,         D0
00001464  B0BC 00000004            563      CMP.L   #ALIEN_MOVE_DELAY,D0
0000146A  6D00 002A                564      BLT     SKIP_NORMAL_MOVE
0000146E  4280                     565      CLR.L   D0                      ; Reset counter
00001470                           566      
00001470                           567      ; Move aliens
00001470  2239 0000241E            568      MOVE.L  ALIENS_X,   D1
00001476  2439 00002426            569      MOVE.L  ALIEN_DIR,  D2
0000147C  2639 000025BE            570      MOVE.L  CURRENT_ALIEN_SPD,D3
00001482  C5C3                     571      MULS    D3,         D2
00001484  D282                     572      ADD.L   D2,         D1
00001486  23C1 0000241E            573      MOVE.L  D1,         ALIENS_X
0000148C  23C0 000025C2            574      MOVE.L  D0,         ALIEN_MOVE_CNT
00001492  6000 004C                575      BRA     CHECK_ALIEN_BOUNDS
00001496                           576      
00001496                           577  SKIP_NORMAL_MOVE:
00001496  23C0 000025C2            578      MOVE.L  D0,         ALIEN_MOVE_CNT
0000149C  4E75                     579      RTS
0000149E                           580      
0000149E                           581  SLOW_ALIEN_MOVE:
0000149E                           582      ; Slow motion - only move every 4th frame
0000149E  2639 000025B6            583      MOVE.L  SLOW_FRAME, D3
000014A4  5283                     584      ADD.L   #1,         D3
000014A6  B6BC 0000000A            585      CMP.L   #SLOW_FACTOR,D3
000014AC  6D00 002A                586      BLT     SKIP_ALIEN_MOVE
000014B0  4283                     587      CLR.L   D3                      ; Reset frame counter
000014B2                           588      
000014B2                           589      ; Move aliens at reduced rate
000014B2  2239 0000241E            590      MOVE.L  ALIENS_X,   D1
000014B8  2439 00002426            591      MOVE.L  ALIEN_DIR,  D2
000014BE  2839 000025BE            592      MOVE.L  CURRENT_ALIEN_SPD,D4
000014C4  C5C4                     593      MULS    D4,         D2
000014C6  D282                     594      ADD.L   D2,         D1
000014C8  23C1 0000241E            595      MOVE.L  D1,         ALIENS_X
000014CE  23C3 000025B6            596      MOVE.L  D3,         SLOW_FRAME
000014D4  6000 000A                597      BRA     CHECK_ALIEN_BOUNDS
000014D8                           598      
000014D8                           599  SKIP_ALIEN_MOVE:
000014D8  23C3 000025B6            600      MOVE.L  D3,         SLOW_FRAME
000014DE  4E75                     601      RTS
000014E0                           602      
000014E0                           603  CHECK_ALIEN_BOUNDS:
000014E0  2239 0000241E            604      MOVE.L  ALIENS_X,   D1
000014E6                           605      
000014E6                           606      ; Calculate rightmost alien X position
000014E6                           607      ; Rightmost alien = ALIENS_X + (ALIEN_COLS-1) * ALIEN_GAP + ALIEN_W
000014E6  2601                     608      MOVE.L  D1,         D3          ; ALIENS_X
000014E8  0683 00000140            609      ADD.L   #((ALIEN_COLS-1)*ALIEN_GAP),D3
000014EE  0683 00000028            610      ADD.L   #ALIEN_W,   D3          ; Right edge of rightmost alien
000014F4                           611      
000014F4                           612      ; Check right boundary (screen width - margin)
000014F4  243C 00000244            613      MOVE.L  #SCR_WIDTH, D2
000014FA  0482 00000000            614      SUB.L   #0,         D2          ; 5 pixel margin from edge
00001500  B682                     615      CMP.L   D2,         D3
00001502  6C00 0010                616      BGE     ALIENS_MOVE_DOWN_LEFT
00001506                           617      
00001506                           618      ; Check left boundary (leftmost alien at ALIENS_X)
00001506  B2BC 00000000            619      CMP.L   #0,         D1          ; 5 pixel margin from edge
0000150C  6F00 0038                620      BLE     ALIENS_MOVE_DOWN_RIGHT
00001510                           621      
00001510  6000 0052                622      BRA     ALIENS_UPDATE_DONE
00001514                           623      
00001514                           624  ALIENS_MOVE_DOWN_LEFT:
00001514  23FC FFFFFFFF 00002426   625      MOVE.L  #-1,        ALIEN_DIR   ; Change direction to left
0000151E  06B9 0000000F 00002422   626      ADD.L   #15,        ALIENS_Y    ; Move down
00001528                           627      ; Push aliens back inside boundary
00001528  223C 00000244            628      MOVE.L  #SCR_WIDTH, D1
0000152E  5B81                     629      SUB.L   #5,         D1
00001530  0481 00000028            630      SUB.L   #ALIEN_W,   D1
00001536  0481 00000140            631      SUB.L   #((ALIEN_COLS-1)*ALIEN_GAP),D1
0000153C  23C1 0000241E            632      MOVE.L  D1,         ALIENS_X
00001542  6000 0020                633      BRA     ALIENS_UPDATE_DONE
00001546                           634      
00001546                           635  ALIENS_MOVE_DOWN_RIGHT:
00001546  23FC 00000001 00002426   636      MOVE.L  #1,         ALIEN_DIR   ; Change direction to right
00001550  06B9 0000000F 00002422   637      ADD.L   #15,        ALIENS_Y    ; Move down
0000155A                           638      ; Push aliens back inside boundary
0000155A  23FC 00000023 0000241E   639      MOVE.L  #35,        ALIENS_X
00001564                           640      
00001564                           641  ALIENS_UPDATE_DONE:
00001564  4E75                     642      RTS
