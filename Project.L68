00001566                           644  *-----------------------------------------------------------
00001566                           645  * Subroutine    : Draw
00001566                           646  * Description   : Draw Screen
00001566                           647  *-----------------------------------------------------------
00001566                           648  DRAW: 
00001566                           649      ; Enable back buffer
00001566  103C 005E                650      MOVE.B  #94,        D0
0000156A  4E4F                     651      TRAP    #15
0000156C                           652  
0000156C                           653      ; Clear the screen (black background)
0000156C  103C 000B                654      MOVE.B  #TC_CURSR_P,D0          ; Set Cursor Position
00001570  323C FF00                655      MOVE.W  #$FF00,     D1          ; Clear contents
00001574  4E4F                     656      TRAP    #15                     ; Trap (Perform action)
00001576                           657  
00001576  6100 05DC                658      BSR     DRAW_STARS              ; Draw stars first (background)
0000157A  6100 007E                659      BSR     DRAW_HUD                ; Draw Score
0000157E  6100 017A                660      BSR     DRAW_SHIP               ; Draw Player Ship
00001582  6100 038A                661      BSR     DRAW_BULLET             ; Draw Bullet
00001586  6100 03CA                662      BSR     DRAW_ALIENS             ; Draw Aliens
0000158A  6100 0A5E                663      BSR     DRAW_ALIEN_BULLETS      ; Draw alien bullets
0000158E                           664      
0000158E                           665      ; Check for game over message
0000158E  2239 00002472            666      MOVE.L  GAME_OVER,  D1
00001594  B2BC 00000001            667      CMP.L   #1,         D1
0000159A  6700 0004                668      BEQ     DRAW_GAME_OVER_MSG
0000159E                           669      
0000159E  4E75                     670      RTS
000015A0                           671  
000015A0                           672  DRAW_GAME_OVER_MSG:
000015A0                           673      ; Draw GAME OVER text
000015A0  103C 000B                674      MOVE.B  #TC_CURSR_P,D0
