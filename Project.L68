000015A8  4E4F                     676      TRAP    #15
000015AA  43F9 000023BE            677      LEA     GAMEOVER_MSG,A1
000015B0  303C 000D                678      MOVE    #13,        D0
000015B4  4E4F                     679      TRAP    #15
000015B6                           680      
000015B6                           681      ; Draw final score label
000015B6  103C 000B                682      MOVE.B  #TC_CURSR_P,D0
000015BA  323C 0F12                683      MOVE.W  #$0F12,     D1          ; Col 15, Row 18
000015BE  4E4F                     684      TRAP    #15
000015C0  43F9 000023D0            685      LEA     FINAL_SCORE_MSG,A1
000015C6  303C 000D                686      MOVE    #13,        D0
000015CA  4E4F                     687      TRAP    #15
000015CC                           688      
000015CC                           689      ; Draw final score value
000015CC  103C 000B                690      MOVE.B  #TC_CURSR_P,D0
000015D0  323C 1C12                691      MOVE.W  #$1C12,     D1          ; Col 28, Row 18
000015D4  4E4F                     692      TRAP    #15
000015D6  103C 0003                693      MOVE.B  #03,        D0
000015DA  2239 0000240E            694      MOVE.L  PLAYER_SCORE,D1
000015E0  4E4F                     695      TRAP    #15
000015E2                           696      
000015E2                           697      ; Draw restart message
000015E2  103C 000B                698      MOVE.B  #TC_CURSR_P,D0
000015E6  323C 0A14                699      MOVE.W  #$0A14,     D1          ; Col 10, Row 20
000015EA  4E4F                     700      TRAP    #15
000015EC  43F9 000023DE            701      LEA     RESTART_MSG,A1
000015F2  303C 000D                702      MOVE    #13,        D0
000015F6  4E4F                     703      TRAP    #15
000015F8  4E75                     704      RTS
000015FA                           705  
000015FA                           706  *-----------------------------------------------------------
000015FA                           707  * Subroutine    : Draw HUD
000015FA                           708  * Description   : Draw Score, Wave, and Slow Motion Status
000015FA                           709  *-----------------------------------------------------------
000015FA                           710  DRAW_HUD:
000015FA                           711      ; Player Score Message
000015FA  103C 000B                712      MOVE.B  #TC_CURSR_P,D0          ; Set Cursor Position
000015FE  323C 0201                713      MOVE.W  #$0201,     D1          ; Col 02, Row 01
00001602  4E4F                     714      TRAP    #15                     ; Trap (Perform action)
00001604  43F9 00002357            715      LEA     SCORE_MSG,  A1          ; Score Message
0000160A  303C 000D                716      MOVE    #13,        D0          ; No Line feed
0000160E  4E4F                     717      TRAP    #15                     ; Trap (Perform action)
00001610                           718  
00001610                           719      ; Player Score Value
00001610  103C 000B                720      MOVE.B  #TC_CURSR_P,D0          ; Set Cursor Position
00001614  323C 0A01                721      MOVE.W  #$0A01,     D1          ; Col 10, Row 01
00001618  4E4F                     722      TRAP    #15                     ; Trap (Perform action)
0000161A  103C 0003                723      MOVE.B  #03,        D0          ; Display number at D1.L
0000161E  2239 0000240E            724      MOVE.L  PLAYER_SCORE,D1         ; Move Score to D1.L
00001624  4E4F                     725      TRAP    #15                     ; Trap (Perform action)
00001626                           726      
00001626                           727      ; Wave Number
00001626  103C 000B                728      MOVE.B  #TC_CURSR_P,D0
0000162A  323C 1401                729      MOVE.W  #$1401,     D1          ; Col 20, Row 01
0000162E  4E4F                     730      TRAP    #15
00001630  43F9 00002360            731      LEA     WAVE_MSG,   A1
00001636  303C 000D                732      MOVE    #13,        D0
0000163A  4E4F                     733      TRAP    #15
0000163C                           734      
0000163C  103C 000B                735      MOVE.B  #TC_CURSR_P,D0
00001640  323C 1A01                736      MOVE.W  #$1A01,     D1          ; Col 26, Row 01
00001644  4E4F                     737      TRAP    #15
00001646  103C 0003                738      MOVE.B  #03,        D0
0000164A  2239 000025BA            739      MOVE.L  WAVE_NUM,   D1
00001650  4E4F                     740      TRAP    #15
00001652                           741      
00001652                           742      ; Slow Motion Status
00001652  103C 000B                743      MOVE.B  #TC_CURSR_P,D0
00001656  323C 2001                744      MOVE.W  #$2001,     D1          ; Col 32, Row 01
0000165A  4E4F                     745      TRAP    #15
0000165C                           746      
0000165C                           747      ; Check if slow motion is active
0000165C  2239 000025AA            748      MOVE.L  SLOW_ACTIVE,D1
00001662  B2BC 00000001            749      CMP.L   #1,         D1
00001668  6700 0048                750      BEQ     DRAW_SLOW_ACTIVE
0000166C                           751      
0000166C                           752      ; Check if on cooldown
0000166C  103C 0008                753      MOVE.B  #8,         D0
00001670  4E4F                     754      TRAP    #15
00001672  2401                     755      MOVE.L  D1,         D2          ; Current time
00001674  2639 000025B2            756      MOVE.L  SLOW_READY_TIME,D3
0000167A  B483                     757      CMP.L   D3,         D2          ; Ready?
0000167C  6C00 006E                758      BGE     DRAW_SLOW_READY
00001680                           759      
00001680                           760      ; On cooldown - show time remaining
00001680  43F9 0000238B            761      LEA     SLOW_CD_MSG,A1
00001686  303C 000D                762      MOVE    #13,        D0
0000168A  4E4F                     763      TRAP    #15
0000168C                           764      
0000168C                           765      ; Calculate seconds remaining
0000168C  103C 000B                766      MOVE.B  #TC_CURSR_P,D0
00001690  323C 2C01                767      MOVE.W  #$2C01,     D1          ; Col 44, Row 01
00001694  4E4F                     768      TRAP    #15
00001696                           769      
00001696  2239 000025B2            770      MOVE.L  SLOW_READY_TIME,D1
0000169C  9282                     771      SUB.L   D2,         D1          ; Time remaining
0000169E  82FC 0064                772      DIVU    #100,       D1          ; Convert to seconds
000016A2  C2BC 0000FFFF            773      AND.L   #$FFFF,     D1
000016A8  103C 0003                774      MOVE.B  #03,        D0
000016AC  4E4F                     775      TRAP    #15
000016AE  6000 0048                776      BRA     HUD_DONE
000016B2                           777      
000016B2                           778  DRAW_SLOW_ACTIVE:
000016B2  43F9 00002378            779      LEA     SLOW_ON_MSG,A1
000016B8  303C 000D                780      MOVE    #13,        D0
000016BC  4E4F                     781      TRAP    #15
000016BE                           782      
000016BE                           783      ; Check if we should display the TIME STOP message
