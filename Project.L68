00001F74                          1751  * Subroutine    : Check Alien Bullet Hit
00001F74                          1752  * Description   : Check if player is hit by alien bullet
00001F74                          1753  *-----------------------------------------------------------
00001F74                          1754  CHECK_ALIEN_BULLET_HIT:
00001F74  41F9 0000253E           1755      LEA     ALN_BLT_ACT,A0
00001F7A  43F9 00002476           1756      LEA     ALN_BLT_X,  A1
00001F80  45F9 000024DA           1757      LEA     ALN_BLT_Y,  A2
00001F86  7E18                    1758      MOVE.L  #MAX_ALN_BLT-1,D7
00001F88                          1759  CHK_HIT_LOOP:
00001F88  2210                    1760      MOVE.L  (A0),       D1
00001F8A  B2BC 00000000           1761      CMP.L   #0,         D1
00001F90  6700 004C               1762      BEQ     NEXT_HIT_CHK
00001F94                          1763      
00001F94                          1764      ; Get bullet position
00001F94  2211                    1765      MOVE.L  (A1),       D1          ; Bullet X
00001F96  2412                    1766      MOVE.L  (A2),       D2          ; Bullet Y
00001F98                          1767      
00001F98                          1768      ; Check collision with ship
00001F98  2639 00002406           1769      MOVE.L  SHIP_X,     D3
00001F9E  B283                    1770      CMP.L   D3,         D1
00001FA0  6D00 003C               1771      BLT     NEXT_HIT_CHK
00001FA4  0683 00000014           1772      ADD.L   #SHIP_W,    D3
00001FAA  B283                    1773      CMP.L   D3,         D1
00001FAC  6E00 0030               1774      BGT     NEXT_HIT_CHK
00001FB0                          1775      
00001FB0  2639 0000240A           1776      MOVE.L  SHIP_Y,     D3
00001FB6  B483                    1777      CMP.L   D3,         D2
00001FB8  6D00 0024               1778      BLT     NEXT_HIT_CHK
00001FBC  0683 0000000A           1779      ADD.L   #SHIP_H,    D3
00001FC2  B483                    1780      CMP.L   D3,         D2
00001FC4  6E00 0018               1781      BGT     NEXT_HIT_CHK
00001FC8                          1782      
00001FC8                          1783      ; HIT! Game over
00001FC8  6100 FC5C               1784      BSR     PLAY_OPPS
00001FCC  23FC 00000001 00002472  1785      MOVE.L  #1,         GAME_OVER
00001FD6  20BC 00000000           1786      MOVE.L  #0,         (A0)        ; Deactivate bullet
00001FDC  4E75                    1787      RTS
00001FDE                          1788      
00001FDE                          1789  NEXT_HIT_CHK:
00001FDE  5888                    1790      ADDA.L  #4,         A0
00001FE0  5889                    1791      ADDA.L  #4,         A1
00001FE2  588A                    1792      ADDA.L  #4,         A2
00001FE4  51CF FFA2               1793      DBRA    D7,         CHK_HIT_LOOP
00001FE8  4E75                    1794      RTS
