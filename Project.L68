00001FEA                          1797  * Subroutine    : Draw Alien Bullets
00001FEA                          1798  * Description   : Draw all active alien bullets (cyan)
00001FEA                          1799  *-----------------------------------------------------------
00001FEA                          1800  DRAW_ALIEN_BULLETS:
00001FEA  41F9 0000253E           1801      LEA     ALN_BLT_ACT,A0
00001FF0  43F9 00002476           1802      LEA     ALN_BLT_X,  A1
00001FF6  45F9 000024DA           1803      LEA     ALN_BLT_Y,  A2
00001FFC  7E18                    1804      MOVE.L  #MAX_ALN_BLT-1,D7
00001FFE                          1805  DRAW_ABL_LOOP:
00001FFE  2218                    1806      MOVE.L  (A0)+,      D1
00002000  B2BC 00000000           1807      CMP.L   #0,         D1
00002006  6700 0020               1808      BEQ     NEXT_ABL_DRAW
0000200A                          1809      
0000200A                          1810      ; Set color (Cyan for alien bullets)
0000200A  223C 00FFFF00           1811      MOVE.L  #CYAN,      D1
00002010  103C 0050               1812      MOVE.B  #80,        D0
00002014  4E4F                    1813      TRAP    #15
00002016                          1814      
00002016                          1815      ; Draw bullet
00002016  2211                    1816      MOVE.L  (A1),       D1          ; X
00002018  2412                    1817      MOVE.L  (A2),       D2          ; Y
0000201A  2601                    1818      MOVE.L  D1,         D3
0000201C  5483                    1819      ADD.L   #ALN_BLT_W, D3          ; X + W
0000201E  2802                    1820      MOVE.L  D2,         D4
00002020  5C84                    1821      ADD.L   #ALN_BLT_H, D4          ; Y + H
00002022  103C 0057               1822      MOVE.B  #87,        D0
00002026  4E4F                    1823      TRAP    #15
00002028                          1824      
00002028                          1825  NEXT_ABL_DRAW:
